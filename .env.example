STRIPE_PRO_YEARLY_PRICE_ID="price_..."
STRIPE_TEAM_MONTHLY_PRICE_ID="price_..."
STRIPE_TEAM_YEARLY_PRICE_ID="price_..."

# ===== APP =====
NEXT_PUBLIC_APP_URL="http://localhost:3000"

